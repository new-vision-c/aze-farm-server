                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔄 FLOW COMPLET - Scénario End-to-End",
      "item": [
        {
          "name": "SCÉNARIO 1: Client achète et reçu livraison",
          "item": [
            {
              "name": "Étape 1: Login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"client@test.com\",\n  \"password\": \"password123\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json(); if(json.accessToken) pm.collectionVariables.set('jwt_token', json.accessToken);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 2: Vider panier existant",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/cart"
              }
            },
            {
              "name": "Étape 3: Ajouter produits",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/cart/items",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"productId\": \"{{product_id_1}}\",\n  \"quantity\": 2\n}"
                }
              }
            },
            {
              "name": "Étape 4: Créer commande",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/orders",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"deliveryAddress\": \"Yaoundé, Mvan\",\n  \"deliveryType\": \"DELIVERY\",\n  \"paymentMethod\": \"ORANGE_MONEY\",\n  \"phoneNumber\": \"691234567\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if(json.orders && json.orders[0]) {",
                      "  pm.collectionVariables.set('order_id', json.orders[0].id);",
                      "  pm.collectionVariables.set('order_number', json.orders[0].orderNumber);",
                      "  if (json.payment) {",
                      "    pm.collectionVariables.set('payment_provider_ref', json.payment.providerRef);",
                      "  }",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 5: Simuler paiement réussi",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/payments/webhook/orange-money",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"pay_token\": \"{{payment_provider_ref}}\",\n  \"status\": \"success\",\n  \"order_id\": \"{{order_id}}\"\n}"
                }
              }
            },
            {
              "name": "Étape 6: Vérifier commande confirmée",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/orders/{{order_id}}"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "pm.test('Commande confirmée', () => {",
                      "  pm.expect(json.status).to.equal('CONFIRMED');",
                      "});"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 7: Login Agriculteur",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"farmer@test.com\",\n  \"password\": \"password123\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json(); if(json.accessToken) pm.collectionVariables.set('jwt_token', json.accessToken);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 8: Marquer en préparation",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/orders/{{order_id}}/status",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"PREPARING\"\n}"
                }
              }
            },
            {
              "name": "Étape 9: Marquer prête",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/orders/{{order_id}}/status",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"READY\"\n}"
                }
              }
            },
            {
              "name": "Étape 10: Générer token livraison",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/orders/{{order_id}}/delivery/confirm"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json();",
                      "if(json.data && json.data.confirmationToken) {",
                      "  pm.collectionVariables.set('delivery_token', json.data.confirmationToken);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 11: Login Client",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/auth/login",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"client@test.com\",\n  \"password\": \"password123\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const json = pm.response.json(); if(json.accessToken) pm.collectionVariables.set('jwt_token', json.accessToken);"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Étape 12: Confirmer réception",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": "{{base_url}}/orders/{{order_id}}/delivery/receive",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"confirmationToken\": \"{{delivery_token}}\"\n}"
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('✅ SCÉNARIO COMPLET RÉUSSI', () => {",
                      "  pm.response.to.have.status(200);",
                      "  const json = pm.response.json();",
                      "  pm.expect(json.data.status).to.equal('DELIVERED');",
                      "  console.log('🎉 Commande', json.data.orderNumber, 'livrée avec succès!');",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
