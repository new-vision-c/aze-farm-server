                  "pm.test('Response has messages array', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('messages');",
                  "    pm.expect(Array.isArray(response.data.messages)).to.be.true;",
                  "});",
                  "",
                  "pm.test('Each message has required fields', () => {",
                  "    const response = pm.response.json();",
