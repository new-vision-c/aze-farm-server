    {
      "name": "🌐 Tests d'internationalisation",
      "item": [
        {
          "name": "🇫🇷 Test avec langue française",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "fr-FR"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"conversationId\": \"{{conversation_id}}\",\n    \"content\": \"Bonjour, je voudrais plus d'informations sur vos produits.\",\n    \"messageType\": \"TEXT\",\n    \"attachments\": [],\n    \"orderId\": null\n}"
            },
            "url": {
