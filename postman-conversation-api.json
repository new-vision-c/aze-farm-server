{
  "info": {
    "_postman_id": "conversation-api-collection",
    "name": "🗣️ Aze Farm - Conversation API Tests",
    "description": "Collection complète pour tester le module conversation avec sécurité, i18n et gestion des données non structurées",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string",
      "description": "Token JWT d'authentification - Remplacer par votre token valide"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "string",
      "description": "ID de conversation généré lors du premier test"
    },
    {
      "key": "message_id",
      "value": "",
      "type": "string",
      "description": "ID de message généré lors des tests"
    },
    {
      "key": "farm_id",
      "value": "YOUR_FARM_ID",
      "type": "string",
      "description": "ID de ferme pour créer une conversation"
    }
  ],
  "item": [
    {
      "name": "🏠 Conversations",
      "item": [
        {
          "name": "📝 Créer ou récupérer une conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"farmId\": \"{{farm_id}}\",\n    \"orderId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations/create-or-get",
              "host": ["{{base_url}}"],
              "path": ["conversations", "create-or-get"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Stocker l'ID de conversation pour les tests suivants",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.conversation && response.data.conversation.id) {",
                  "        pm.collectionVariables.set('conversation_id', response.data.conversation.id);",
                  "        console.log('Conversation ID sauvegardé:', response.data.conversation.id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status code is 201', () => {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "pm.test('Response has conversation data', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('conversation');",
                  "    pm.expect(response.data.conversation).to.have.property('id');",
                  "    pm.expect(response.data.conversation).to.have.property('consumerId');",
                  "    pm.expect(response.data.conversation).to.have.property('farmId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "📋 Lister les conversations de l'utilisateur",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/conversations",
              "host": ["{{base_url}}"],
              "path": ["conversations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test('Response has conversations array', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('conversations');",
                  "    pm.expect(Array.isArray(response.data.conversations)).to.be.true;",
                  "});",
                  "",
                  "pm.test('Each conversation has required fields', () => {",
                  "    const response = pm.response.json();",
                  "    response.data.conversations.forEach(conv => {",
                  "        pm.expect(conv).to.have.property('id');",
                  "        pm.expect(conv).to.have.property('consumerId');",
                  "        pm.expect(conv).to.have.property('farmId');",
                  "        pm.expect(conv).to.have.property('status');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "💬 Messages",
      "item": [
        {
          "name": "📤 Envoyer un message texte (sécurisé)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"conversationId\": \"{{conversation_id}}\",\n    \"content\": \"Bonjour ! Je suis intéressé par vos produits. <script>alert('XSS test')</script>\",\n    \"messageType\": \"TEXT\",\n    \"attachments\": [],\n    \"orderId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations/messages/send",
              "host": ["{{base_url}}"],
              "path": ["conversations", "messages", "send"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Stocker l'ID du message pour les tests suivants",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.message && response.data.message.id) {",
                  "        pm.collectionVariables.set('message_id', response.data.message.id);",
                  "        console.log('Message ID sauvegardé:', response.data.message.id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status code is 201', () => {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "pm.test('XSS protection - script tags removed', () => {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.message) {",
                  "        const content = response.data.message.content;",
                  "        pm.expect(content).to.not.include('<script>');",
                  "        pm.expect(content).to.not.include('alert');",
                  "        console.log('XSS protection test passed - content sanitized:', content);",
                  "    }",
                  "});",
                  "",
                  "pm.test('Response has message data', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('message');",
                  "    pm.expect(response.data.message).to.have.property('id');",
                  "    pm.expect(response.data.message).to.have.property('content');",
                  "    pm.expect(response.data.message).to.have.property('senderId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "📤 Envoyer un message avec pièce jointe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"conversationId\": \"{{conversation_id}}\",\n    \"content\": \"Voici une image de test\",\n    \"messageType\": \"IMAGE\",\n    \"attachments\": [\"https://example.com/test-image.jpg\"],\n    \"orderId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations/messages/send",
