                  "        pm.expect(msg).to.have.property('content');",
                  "        pm.expect(msg).to.have.property('senderId');",
                  "        pm.expect(msg).to.have.property('messageType');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
