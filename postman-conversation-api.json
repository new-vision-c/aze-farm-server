    {
      "name": "🔒 Tests de sécurité",
      "item": [
        {
          "name": "🚨 Test XSS - Script injection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"conversationId\": \"{{conversation_id}}\",\n    \"content\": \"<script>alert('XSS Attack')</script><img src=x onerror=alert('XSS')><iframe src=javascript:alert('XSS')>\",\n    \"messageType\": \"TEXT\",\n    \"attachments\": [],\n    \"orderId\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/conversations/messages/send",
              "host": ["{{base_url}}"],
              "path": ["conversations", "messages", "send"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', () => {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "});",
                  "",
                  "pm.test('XSS protection - all dangerous tags removed', () => {",
                  "    const response = pm.response.json();",
                  "    const content = response.data.message.content;",
                  "    ",
                  "    // Vérifier que les tags dangereux sont supprimés",
                  "    pm.expect(content).to.not.include('<script>');",
                  "    pm.expect(content).to.not.include('</script>');",
                  "    pm.expect(content).to.not.include('onerror');",
                  "    pm.expect(content).to.not.include('iframe');",
                  "    pm.expect(content).to.not.include('javascript:');",
                  "    ",
                  "    console.log('XSS Protection Test - Content sanitized:', content);",
                  "});",
                  "",
                  "pm.test('Content is safe HTML', () => {",
                  "    const response = pm.response.json();",
                  "    const content = response.data.message.content;",
                  "    ",
                  "    // Le contenu doit être sécurisé mais lisible",
                  "    pm.expect(content.length).to.be.greaterThan(0);",
                  "    pm.expect(typeof content).to.eql('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "🚫 Test validation - Accès non autorisé",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/conversations/invalid-conversation-id/messages",
              "host": ["{{base_url}}"],
              "path": ["conversations", "invalid-conversation-id", "messages"]
