        {
          "name": "📥 Lister les messages d'une conversation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/conversations/{{conversation_id}}/messages?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "page",
